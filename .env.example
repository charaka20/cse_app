# CSE Tracker — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV: Copy to .env and fill in values.
#   cp .env.example .env
#
# GITHUB ACTIONS: Add as repository secrets at:
#   Settings → Secrets and variables → Actions → New repository secret
#
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# DeepSeek API — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxYZ

# Telegram Chat ID — your private chat ID or group/channel ID
# Positive number = private chat (e.g. 987654321)
# Negative number = group/channel (e.g. -1001234567890)
TELEGRAM_CHAT_ID=987654321
